    "jszip": "^3.10.0",
    "papaparse": "^5.5.0"
  },
  "peerDependencies": {
    "@napi-rs/canvas": "^0.1.0"
  },
  "peerDependenciesMeta": {
    "@napi-rs/canvas": {
      "optional": true
    }
  },
  "devDependencies": {
    "@mbtech-nl/tsconfig": "^1.0.1",
    "@napi-rs/canvas": "^0.1.0",
    "@types/node": "^22.0.0",
    "@types/papaparse": "^5.3.0",
    "@vitest/coverage-v8": "^2.0.0",
    "typescript": "~5.5.0",
    "vitest": "^2.0.0"
  }
